{
  "name": "vietedu-smart-pro",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "main.cjs",
  "author": "Thanh Tung",
  "description": "Tro ly giao duc thong minh - Truong Binh Hoa",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "npm run build && electron-builder"
  },
  "build": {
    "appId": "com.vietedu.smartpro",
    "productName": "VietEdu Smart Pro",
    "copyright": "Copyright © 2026 Thanh Tung",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "main.cjs",
      "sounds/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "dist/logo-app.png"
    },
    "nsis": {
      "oneClick": true,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VietEdu Smart Pro"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@google/generative-ai": "^0.24.1",
    "@supabase/supabase-js": "^2.99.1",
    "@tailwindcss/vite": "^4.1.18",
    "canvas-confetti": "^1.9.4",
    "cors": "^2.8.6",
    "docx": "^9.6.1",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "file-saver": "^2.0.5",
    "firebase": "^12.10.0",
    "framer-motion": "^12.33.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.577.0",
    "mammoth": "^1.11.0",
    "multer": "^2.0.2",
    "pptxgenjs": "^4.0.1",
    "react": "^19.2.0",
    "react-confetti": "^6.4.0",
    "react-dom": "^19.2.0",
    "react-pdf": "^10.3.0",
    "react-router-dom": "^7.13.0",
    "recharts": "^3.8.0",
    "tailwindcss": "^4.1.18",
    "tesseract.js": "^7.0.0",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/express": "^4.17.25",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.1",
    "cross-env": "^10.1.0",
    "electron": "^41.0.3",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "globals": "^16.5.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.48.0",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  }
}